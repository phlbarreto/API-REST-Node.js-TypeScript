{
  "name": "api-rest-node.js-typescript",
  "version": "1.0.0",
  "description": "- **Node.js + Express**\r - **TypeScript**\r - **PostgreSQL** (com Prisma)\r - **JWT** (autenticação)\r - **Zod** (validação de dados)",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run services:up && npm run migrations:up && npm run migrations:generate && npm run server:watch",
    "services:up": "docker compose -f src/infra/compose.yaml up -d && npm run services:wait:database ",
    "services:down": "docker compose -f src/infra/compose.yaml down -v",
    "services:wait:database": "node src/infra/scripts/wait-for-postgres.ts",
    "migrations:create": "dotenv -e .env -- prisma migrate dev --name",
    "migrations:up": "dotenv -e .env -- prisma migrate dev",
    "migrations:reset": "dotenv -e .env -- prisma migrate reset --force",
    "migrations:generate": "prisma generate",
    "migrations:deploy": "npm run migrations:generate && dotenv -e .env -- prisma migrate deploy",
    "server:watch": "tsx --watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node api/index.js",
    "test": "npm run services:up && npm run migrations:up && npm run migrations:generate && concurrently -k -s first -n \"server,test\" --hide server \"tsx src/server.ts\" vitest",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phlbarreto/API-REST-Node.js-TypeScript.git"
  },
  "keywords": [],
  "author": "Pedro Barreto - https://github.com/phlbarreto",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/phlbarreto/API-REST-Node.js-TypeScript/issues"
  },
  "homepage": "https://github.com/phlbarreto/API-REST-Node.js-TypeScript#readme",
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "bcrypt": "6.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "17.2.2",
    "dotenv-expand": "12.0.3",
    "express": "5.1.0",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@types/async-retry": "^1.4.9",
    "@types/bcrypt": "6.0.0",
    "@types/cookie-parser": "1.4.9",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "async-retry": "1.3.3",
    "concurrently": "9.2.1",
    "dotenv-cli": "11.0.0",
    "prisma": "7.7.0",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": "24"
  }
}
