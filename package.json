{
  "name": "api-rest-node.js-typescript",
  "version": "1.0.0",
  "description": "- **Node.js + Express**\r - **TypeScript**\r - **PostgreSQL** (com Prisma)\r - **JWT** (autenticação)\r - **Zod** (validação de dados)",
  "main": "index.js",
  "scripts": {
    "services:up": "docker compose -f src/infra/compose.yaml up -d",
    "services:wait:database": "node src/infra/scripts/wait-for-postgres.ts",
    "migrations:up": "dotenv -e .env -- npx prisma migrate dev",
    "server:watch": "tsx --watch src/server.ts",
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && npm run server:watch",
    "services:down": "docker compose -f src/infra/compose.yaml down -v",
    "migrations:create": "npx prisma migrate dev --name",
    "start": "node ./dist/server.js",
    "postinstall": "prisma generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phlbarreto/API-REST-Node.js-TypeScript.git"
  },
  "keywords": [],
  "author": "Pedro Barreto - https://github.com/phlbarreto",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/phlbarreto/API-REST-Node.js-TypeScript/issues"
  },
  "homepage": "https://github.com/phlbarreto/API-REST-Node.js-TypeScript#readme",
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "bcrypt": "6.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "17.2.2",
    "dotenv-expand": "12.0.3",
    "express": "5.1.0",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/cookie-parser": "1.4.9",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "concurrently": "9.2.1",
    "dotenv-cli": "11.0.0",
    "prisma": "7.7.0",
    "tsx": "4.21.0"
  },
  "engines": {
    "node": "24"
  }
}
