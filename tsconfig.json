{
  "compilerOptions": {
    "target": "ES2025",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "removeComments": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./prisma/*"],
      "$/*": ["./tests/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["src", "tests", "prisma"],
  "exclude": ["node_modules", "dist"]
}
